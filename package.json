{
  "name": "yielded",
  "version": "0.0.1",
  "description": "A TypeScript library for composing and transforming values from synchronous iterables and asynchronous generators through a uniform, lazy-evaluated pipeline API",
  "keywords": [
    "iterator",
    "iterable",
    "generator",
    "async",
    "lazy",
    "pipeline",
    "stream",
    "functional",
    "typescript",
    "parallel"
  ],
  "author": "jEnbuska",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jEnbuska/yielded.git"
  },
  "bugs": {
    "url": "https://github.com/jEnbuska/yielded/issues"
  },
  "homepage": "https://github.com/jEnbuska/yielded#readme",
  "module": "./src/index.ts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "validate": "tsc --noEmit",
    "validate:watch": "tsc --watch",
    "build": "tsup && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "USE_POLYFILLS=true vitest run --coverage && vitest run --coverage",
    "test:watch": "vitest --ui",
    "lint": "eslint --ext .ts --max-warnings 0 ./src",
    "lint:fix": "eslint --fix --ext .ts ./src",
    "prettier": "prettier --check ./src",
    "prettier:write": "prettier --write ./src"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "colors": "^1.4.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
